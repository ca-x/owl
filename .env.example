OWL_PORT=8080
OWL_FRONTEND_PORT=3000
OWL_JWT_SECRET=change-me-in-production
OWL_BOOTSTRAP_ADMIN=true
OWL_ADMIN_USERNAME=admin
OWL_ADMIN_PASSWORD=admin123456
OWL_DATA_DIR=/app/data
OWL_UPLOADS_DIR=/app/data/uploads
OWL_LIBRARY_DIR=/app/data/uploads
OWL_DB_PATH=/app/data/data.db
OWL_FRONTEND_ORIGIN=*

# Optional Redis-backed MDX exact/prefix index cache
OWL_REDIS_ADDR=
OWL_REDIS_PASSWORD=
OWL_REDIS_DB=0
OWL_REDIS_KEY_PREFIX=owl:mdx:index
OWL_REDIS_PREFIX_MAX_LEN=8
