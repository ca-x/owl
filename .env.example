OWL_PORT=8080
OWL_FRONTEND_PORT=3000
OWL_JWT_SECRET=change-me-in-production
OWL_BOOTSTRAP_ADMIN=true
OWL_ADMIN_USERNAME=admin
OWL_ADMIN_PASSWORD=admin123456
OWL_DATA_DIR=/app/data
OWL_UPLOADS_DIR=/app/data/uploads
OWL_LIBRARY_DIR=/app/data/uploads
OWL_DB_PATH=/app/data/data.db
# Database options: sqlite (default), postgres, mysql.
#
# SQLite (default): leave OWL_DB_DSN empty to use OWL_DB_PATH, or set an explicit DSN.
# OWL_DB_TYPE=sqlite
# OWL_DB_DSN=file:/app/data/data.db?cache=shared&_pragma=foreign_keys(1)&_pragma=journal_mode(WAL)&_pragma=synchronous(NORMAL)&_pragma=busy_timeout(10000)
#
# PostgreSQL example:
# OWL_DB_TYPE=postgres
# OWL_DB_DSN=postgres://owl:owl_password@postgres:5432/owl?sslmode=disable
#
# MySQL/MariaDB example:
# OWL_DB_TYPE=mysql
# OWL_DB_DSN=owl:owl_password@tcp(mysql:3306)/owl?parseTime=true&charset=utf8mb4&loc=Local
OWL_DB_TYPE=sqlite
OWL_DB_DSN=
OWL_FRONTEND_ORIGIN=*

# Optional Redis-backed MDX exact/prefix index cache
OWL_REDIS_ADDR=
OWL_REDIS_PASSWORD=
OWL_REDIS_DB=0
OWL_REDIS_KEY_PREFIX=owl:mdx:index
OWL_REDIS_PREFIX_MAX_LEN=8
OWL_REDIS_SEARCH_ENABLED=true
OWL_REDIS_SEARCH_KEY_PREFIX=owl:mdx:search
OWL_AUDIO_CACHE_DIR=/app/data/cache/audio
FFMPEG_BIN=/usr/bin/ffmpeg
